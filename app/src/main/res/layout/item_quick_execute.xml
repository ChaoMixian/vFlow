<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="64dp"
    android:paddingHorizontal="20dp"
    android:paddingVertical="8dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quick_execute_icon_container"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:rippleColor="?attr/colorPrimary"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/quick_execute_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            app:tint="?attr/colorOnPrimaryContainer"
            tools:src="@drawable/rounded_play_arrow_24" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/quick_execute_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/quick_execute_icon_container"
        android:layout_marginStart="16dp"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        tools:text="每日签到" />

</RelativeLayout>
